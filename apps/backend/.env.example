DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/fastfood_abastecimiento_es?schema=public"
PORT=3000
HOST=0.0.0.0

# Firma de JWT (HS256). En produccion usa un valor largo y secreto (32+ caracteres recomendado).
JWT_SECRET="cambiar-por-secreto-largo-en-produccion-minimo-32-caracteres"

# Contrasena de los tres usuarios de demo al ejecutar npm run db:seed (opcional).
# Por defecto en seed: FastFood2026!
# SEED_DEMO_PASSWORD="FastFood2026!"
