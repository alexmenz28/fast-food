{
  "name": "fast-food-abastecimiento",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:all": "concurrently -n backend,web -c blue,magenta \"npm run dev -w backend\" \"npm run dev -w web\"",
    "dev:backend": "npm run dev -w backend",
    "dev:web": "npm run dev -w web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
